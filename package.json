{
    "name": "@andy-defer/aurora-ui",
    "version": "0.1.1",
    "description": "A modern, accessible, and customizable React component library - built with Tailwind CSS",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.mjs",
            "require": "./dist/*.js"
        },
        "./styles.css": "./dist/styles.css"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format esm,cjs --dts --clean --external react",
        "build:css": "tailwindcss -i src/styles.css -o dist/styles.css",
        "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
        "lint": "eslint src --ext .ts,.tsx",
        "test": "vitest",
        "prepublishOnly": "npm run build && npm run build:css"
    },
    "peerDependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tailwindcss": "^3.0.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "autoprefixer": "^10.4.0",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.0.0",
        "eslint": "^8.0.0",
        "postcss": "^8.4.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tailwind-merge": "^2.0.0",
        "tailwindcss": "^3.4.0",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0",
        "vitest": "^1.0.0"
    },
    "dependencies": {
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.0.0",
        "lucide-react": "^1.25.0",
        "tailwind-merge": "^2.0.0"
    },
    "keywords": [
        "react",
        "ui-library",
        "components",
        "tailwind",
        "tailwindcss",
        "design-system",
        "accessible",
        "typescript",
        "aurora-ui",
        "react-components",
        "theming"
    ],
    "author": {
        "name": "Andy Defer",
        "email": "andy@defer.dev",
        "url": "https://github.com/andy-defer"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/andy-defer/aurora-ui.git"
    },
    "bugs": {
        "url": "https://github.com/andy-defer/aurora-ui/issues"
    },
    "homepage": "https://github.com/andy-defer/aurora-ui#readme"
}
